# B3 Day Trade Analyzer - Configuracao
# Copie este arquivo para .env e ajuste os valores

# Fonte de dados: yfinance (gratuito), bridge (Profit/Tryd), brapi
DATA_SOURCE=yfinance

# Porta do servidor
PORT=8080

# URL do bridge Profit Pro / Tryd (se usar bridge)
BRIDGE_URL=http://localhost:8081

# Token da API Brapi (se usar brapi)
BRAPI_TOKEN=